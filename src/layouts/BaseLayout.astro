---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import CookieConsent from "../components/CookieConsent.astro";

const {
  title = "Nova Raiz",
  description = "Transição consciente da cidade para o interior: planejamento, trabalho remoto e vida real.",
  canonical
} = Astro.props;

const canonicalUrl = canonical ?? Astro.url.href;
const adsenseClientId = import.meta.env.PUBLIC_ADSENSE_CLIENT_ID ?? "ca-pub-4613426749830025";
const shouldLoadAdsense = Boolean(adsenseClientId);
---

<!doctype html>
<html lang="pt-br">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:type" content="website" />
<meta property="og:url" content={canonicalUrl} />
    <link rel="canonical" href={canonicalUrl} />
    <meta name="theme-color" content="#1F3A2E" />
    {shouldLoadAdsense && (
      <>
        <meta name="google-adsense-account" content={adsenseClientId} />
        <script
          async
          src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${adsenseClientId}`}
          crossorigin="anonymous"
        ></script>
      </>
    )}

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Playfair+Display:wght@600;700&display=swap" rel="stylesheet">
  </head>
  <body class="min-h-screen">
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "WebSite",
        "name": "Nova Raiz",
        "url": "https://novaraiz.netlify.app",
        "description": "Transição consciente da cidade para o interior: planejamento, trabalho remoto e vida real.",
        "publisher": {
          "@type": "Organization",
          "name": "Nova Raiz",
          "url": "https://novaraiz.netlify.app",
          "logo": "https://novaraiz.netlify.app/logo.png"
        }
      }
    </script>
    <Header />
    <main class="mx-auto max-w-6xl px-4 md:px-6">
      <slot />
    </main>
    <Footer />
    <CookieConsent />
  </body>
</html>
